{
  "packageManager": "pnpm@10.30.1",
  "name": "ade",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "check": "pnpm exec eslint . && pnpm --filter @ade/api typecheck && pnpm --filter @ade/api test && pnpm --filter @ade/web build",
    "check:python": "uv build --directory python/ade-engine && uv build --directory python/ade-config-template",
    "build": "node scripts/build.mjs",
    "start": "node scripts/start.mjs",
    "smoke:start": "node scripts/smoke-start.mjs",
    "clean": "node scripts/clean.mjs",
    "smoke": "node scripts/smoke-start.mjs",
    "dev:web": "pnpm --filter @ade/web dev",
    "dev:api": "pnpm --filter @ade/api dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.57.1"
  }
}
