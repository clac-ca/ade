{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts",
    "apps/ade-api/sandbox-environment/**/*.ts"
  ]
}
