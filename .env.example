# ADE runtime
HOST=0.0.0.0
PORT=8000

# Required runtime services
# pnpm start fails fast if SQL is missing or unreachable.
# These examples are for pnpm start and assume local SQL Server and Azurite are already running on the host.
AZURE_SQL_CONNECTIONSTRING=Server=host.docker.internal,8013;Database=ade;User Id=sa;Password=<LOCAL_SQL_PASSWORD>;Encrypt=false;TrustServerCertificate=true

# Storage: set exactly one
AZURE_STORAGEBLOB_CONNECTIONSTRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFeqCnf2fV4i+7VQ8Jtq/K1SZFPTOtr/KBHBeksoGMGwP/IQ+J4MJBxRcQ6vL6gE0Gv6hA==;BlobEndpoint=http://host.docker.internal:8010/devstoreaccount1;QueueEndpoint=http://host.docker.internal:8011/devstoreaccount1;TableEndpoint=http://host.docker.internal:8012/devstoreaccount1
# AZURE_STORAGEBLOB_RESOURCEENDPOINT=https://<storage-account>.blob.core.windows.net/
