FROM node:22-alpine

WORKDIR /app
ARG ADE_BUILD_VERSION=dev
ARG ADE_BUILD_GIT_SHA=dev
ARG ADE_BUILD_TIMESTAMP=unknown
ENV NODE_ENV=production
ENV ADE_BUILD_VERSION=$ADE_BUILD_VERSION
ENV ADE_BUILD_GIT_SHA=$ADE_BUILD_GIT_SHA
ENV ADE_BUILD_TIMESTAMP=$ADE_BUILD_TIMESTAMP

COPY .package/ ./

EXPOSE 8001

CMD ["node", "dist/server.js"]
