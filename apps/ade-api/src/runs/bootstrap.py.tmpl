import fcntl
import importlib.metadata
import json
import os
import subprocess
import sys
import threading
from pathlib import Path

CONFIG = json.loads({{CONFIG_JSON}})
SESSION_ROOT = Path("/mnt/data")
INPUT_PATH = Path(CONFIG["inputPath"])
OUTPUT_DIR = Path(CONFIG["outputDir"])
INSTALL_LOCK_PATH = Path(CONFIG["installLockPath"])


def event_payload(payload):
    return json.dumps(payload, separators=(",", ":"))


class StdoutEmitter:
    def __init__(self):
        self._lock = threading.Lock()

    def __enter__(self):
        return self

    def __exit__(self, exc_type, exc, tb):
        return False

    def ready(self):
        return

    def emit(self, payload):
        with self._lock:
            print(CONFIG["eventSentinelPrefix"] + event_payload(payload), flush=True)


class WebSocketEmitter:
    def __init__(self):
        self.socket = None
        self.control_thread = None
        self.send_lock = threading.Lock()
        self.stop_event = threading.Event()

    def __enter__(self):
        ensure_websockets()
        from websockets.sync.client import connect

        self.socket = connect(
            CONFIG["bridgeUrl"],
            ping_interval=20,
            ping_timeout=20,
            max_size=None,
        )
        self.control_thread = threading.Thread(
            target=self.listen_for_control,
            daemon=True,
        )
        self.control_thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self.stop_event.set()
        if self.socket is not None:
            self.socket.close()
        if self.control_thread is not None:
            self.control_thread.join(timeout=1)
        return False

    def ready(self):
        self.emit({"type": "ready"})

    def emit(self, payload):
        with self.send_lock:
            self.socket.send(event_payload(payload))

    def listen_for_control(self):
        try:
            while not self.stop_event.is_set():
                try:
                    message = self.socket.recv(timeout=1)
                except TimeoutError:
                    continue
                payload = json.loads(message)
                if payload.get("type") == "cancel":
                    os._exit(130)
        except Exception:
            return


def ensure_websockets():
    try:
        from websockets.sync.client import connect  # noqa: F401
    except ModuleNotFoundError:
        subprocess.run(
            [sys.executable, "-m", "pip", "install", "websockets>=12,<16"],
            check=True,
        )


def emitter():
    if CONFIG.get("bridgeUrl"):
        return WebSocketEmitter()
    return StdoutEmitter()


def emit_status(sink, phase, state):
    sink.emit({"type": "status", "phase": phase, "state": state})


def emit_log(sink, phase, level, message):
    sink.emit(
        {"type": "log", "phase": phase, "level": level, "message": message.rstrip("\n")}
    )


def emit_error(sink, phase, message, retriable):
    sink.emit(
        {
            "type": "error",
            "phase": phase,
            "message": str(message),
            "retriable": retriable,
        }
    )


def stream_subprocess(sink, phase, argv):
    process = subprocess.Popen(
        argv,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        encoding="utf-8",
        errors="replace",
        bufsize=1,
    )
    pump_errors = []

    def pump(stream, level):
        try:
            for line in iter(stream.readline, ""):
                emit_log(sink, phase, level, line)
        except Exception as error:
            pump_errors.append(error)
            process.kill()
        finally:
            stream.close()

    stdout_thread = threading.Thread(
        target=pump,
        args=(process.stdout, "info"),
        daemon=True,
    )
    stderr_thread = threading.Thread(
        target=pump,
        args=(process.stderr, "error"),
        daemon=True,
    )
    stdout_thread.start()
    stderr_thread.start()
    return_code = process.wait()
    stdout_thread.join()
    stderr_thread.join()
    if pump_errors:
        raise pump_errors[0]
    if return_code != 0:
        raise subprocess.CalledProcessError(return_code, argv)


def installed_version(package_name):
    try:
        return importlib.metadata.version(package_name)
    except importlib.metadata.PackageNotFoundError:
        return None


def ensure_package(sink, phase, package_name, expected_version, wheel_path, install_args):
    if installed_version(package_name) == expected_version:
        emit_log(
            sink,
            phase,
            "info",
            f"{package_name} {expected_version} already installed",
        )
        return

    stream_subprocess(
        sink,
        phase,
        [
            sys.executable,
            "-m",
            "pip",
            "install",
            *install_args,
            wheel_path,
        ],
    )


def install_packages(sink):
    emit_status(sink, "installPackages", "started")
    INSTALL_LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    with INSTALL_LOCK_PATH.open("w") as install_lock_file:
        fcntl.flock(install_lock_file.fileno(), fcntl.LOCK_EX)
        ensure_package(
            sink,
            "installPackages",
            CONFIG["enginePackageName"],
            CONFIG["engineVersion"],
            CONFIG["engineWheelPath"],
            ["--force-reinstall"],
        )
        ensure_package(
            sink,
            "installPackages",
            CONFIG["configPackageName"],
            CONFIG["configVersion"],
            CONFIG["configWheelPath"],
            ["--no-deps", "--force-reinstall"],
        )
    emit_status(sink, "installPackages", "completed")


def execute_run(sink):
    emit_status(sink, "executeRun", "started")
    from ade_engine import load_config, process as run_process

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    config = load_config("ade_config", name="ade-config")
    result = run_process(
        config=config,
        input_path=INPUT_PATH,
        output_dir=OUTPUT_DIR,
    )

    sink.emit(
        {
            "type": "result",
            "outputPath": result.output_path.relative_to(SESSION_ROOT).as_posix(),
            "validationIssues": [
                {
                    "rowIndex": issue.row_index,
                    "field": issue.field,
                    "message": issue.message,
                }
                for issue in result.validation_issues
            ],
        }
    )


def main():
    with emitter() as sink:
        sink.ready()
        try:
            install_packages(sink)
            execute_run(sink)
        except Exception as error:
            phase = "installPackages" if installed_version(CONFIG["enginePackageName"]) != CONFIG["engineVersion"] else "executeRun"
            retriable = phase == "installPackages"
            emit_error(sink, phase, error, retriable)
            raise


if __name__ == "__main__":
    main()
