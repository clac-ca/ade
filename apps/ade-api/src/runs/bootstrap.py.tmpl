import fcntl
import importlib.metadata
import json
import os
import subprocess
import sys
import threading
import urllib.request
from pathlib import Path

CONFIG = json.loads({{CONFIG_JSON}})
INSTALL_LOCK_PATH = Path(CONFIG["installLockPath"])
LOCAL_INPUT_PATH = Path(CONFIG["localInputPath"])
LOCAL_OUTPUT_DIR = Path(CONFIG["localOutputDir"])
PROCESS_RESULT_PREFIX = "__ADE_PROCESS_RESULT__="


def event_payload(payload):
    return json.dumps(payload, separators=(",", ":"))


class AdePhaseError(Exception):
    def __init__(self, phase, message, *, retriable=False):
        super().__init__(str(message))
        self.phase = phase
        self.retriable = retriable


class WebSocketEmitter:
    def __init__(self):
        self.socket = None
        self.control_thread = None
        self.send_lock = threading.Lock()
        self.stop_event = threading.Event()

    def __enter__(self):
        ensure_websockets()
        from websockets.sync.client import connect

        self.socket = connect(
            CONFIG["bridgeUrl"],
            ping_interval=20,
            ping_timeout=20,
            max_size=None,
        )
        self.control_thread = threading.Thread(
            target=self.listen_for_control,
            daemon=True,
        )
        self.control_thread.start()
        return self

    def __exit__(self, exc_type, exc, tb):
        self.stop_event.set()
        if self.socket is not None:
            self.socket.close()
        if self.control_thread is not None:
            self.control_thread.join(timeout=1)
        return False

    def ready(self):
        self.emit({"type": "ready"})

    def emit(self, payload):
        with self.send_lock:
            self.socket.send(event_payload(payload))

    def listen_for_control(self):
        try:
            while not self.stop_event.is_set():
                try:
                    message = self.socket.recv(timeout=1)
                except TimeoutError:
                    continue
                payload = json.loads(message)
                if payload.get("type") == "cancel":
                    os._exit(130)
        except Exception:
            return


def ensure_websockets():
    try:
        from websockets.sync.client import connect  # noqa: F401
    except ModuleNotFoundError:
        subprocess.run(
            [sys.executable, "-m", "pip", "install", "websockets>=12,<16"],
            check=True,
        )


def emit_error(sink, phase, message, retriable):
    sink.emit(
        {
            "type": "error",
            "phase": phase,
            "message": str(message),
            "retriable": retriable,
        }
    )


def emit_log(sink, phase, level, message):
    sink.emit(
        {"type": "log", "phase": phase, "level": level, "message": message.rstrip("\n")}
    )


def emit_status(sink, phase, state):
    sink.emit({"type": "status", "phase": phase, "state": state})


def http_request(method, access, body=None):
    request = urllib.request.Request(
        access["url"],
        data=body,
        method=method,
    )
    for header_name, header_value in access.get("headers", {}).items():
        request.add_header(header_name, header_value)

    with urllib.request.urlopen(request) as response:
        return response.read()


def download_input():
    try:
        LOCAL_INPUT_PATH.parent.mkdir(parents=True, exist_ok=True)
        body = http_request("GET", CONFIG["inputDownload"])
        LOCAL_INPUT_PATH.write_bytes(body)
    except Exception as error:
        raise AdePhaseError("executeRun", error) from error


def ensure_package(sink, phase, package_name, expected_version, wheel_path, install_args):
    try:
        installed_version = importlib.metadata.version(package_name)
    except importlib.metadata.PackageNotFoundError:
        installed_version = None
    if installed_version == expected_version:
        emit_log(sink, phase, "info", f"{package_name} {expected_version} already installed")
        return
    stream_subprocess(
        sink,
        phase,
        [
            sys.executable,
            "-m",
            "pip",
            "install",
            *install_args,
            wheel_path,
        ],
        expect_result=False,
    )


def install_packages(sink):
    emit_status(sink, "installPackages", "started")
    INSTALL_LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    try:
        with INSTALL_LOCK_PATH.open("w") as install_lock_file:
            fcntl.flock(install_lock_file.fileno(), fcntl.LOCK_EX)
            ensure_package(
                sink,
                "installPackages",
                CONFIG["enginePackageName"],
                CONFIG["engineVersion"],
                CONFIG["engineWheelPath"],
                ["--force-reinstall"],
            )
            ensure_package(
                sink,
                "installPackages",
                CONFIG["configPackageName"],
                CONFIG["configVersion"],
                CONFIG["configWheelPath"],
                ["--no-deps", "--force-reinstall"],
            )
    except Exception as error:
        raise AdePhaseError("installPackages", error, retriable=True) from error
    emit_status(sink, "installPackages", "completed")


def processor_code():
    return """
import json
import sys
from pathlib import Path
from ade_engine import load_config
from ade_engine.runner import process

PROCESS_RESULT_PREFIX = "__ADE_PROCESS_RESULT__="

input_path = Path(sys.argv[1])
output_dir = Path(sys.argv[2])
config = load_config("ade_config", name="ade-config")
result = process(config=config, input_path=input_path, output_dir=output_dir)
print(
    PROCESS_RESULT_PREFIX
    + json.dumps(
        {
            "localOutputPath": str(result.output_path),
            "validationIssues": [
                {
                    "rowIndex": issue.row_index,
                    "field": issue.field,
                    "message": issue.message,
                }
                for issue in result.validation_issues
            ],
        },
        separators=(",", ":"),
    ),
    flush=True,
)
"""


def stream_subprocess(sink, phase, argv, *, expect_result):
    process = subprocess.Popen(
        argv,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        encoding="utf-8",
        errors="replace",
        bufsize=1,
    )
    result_payload = None
    pump_errors = []

    def pump_stdout(stream):
        nonlocal result_payload
        try:
            for line in iter(stream.readline, ""):
                if line.startswith(PROCESS_RESULT_PREFIX):
                    result_payload = json.loads(line[len(PROCESS_RESULT_PREFIX):])
                    continue
                emit_log(sink, phase, "info", line)
        except Exception as error:
            pump_errors.append(error)
            process.kill()
        finally:
            stream.close()

    def pump_stderr(stream):
        try:
            for line in iter(stream.readline, ""):
                emit_log(sink, phase, "error", line)
        except Exception as error:
            pump_errors.append(error)
            process.kill()
        finally:
            stream.close()

    stdout_thread = threading.Thread(target=pump_stdout, args=(process.stdout,), daemon=True)
    stderr_thread = threading.Thread(target=pump_stderr, args=(process.stderr,), daemon=True)
    stdout_thread.start()
    stderr_thread.start()
    return_code = process.wait()
    stdout_thread.join()
    stderr_thread.join()

    if pump_errors:
        raise pump_errors[0]
    if return_code != 0:
        raise subprocess.CalledProcessError(return_code, argv)
    if expect_result and result_payload is None:
        raise RuntimeError("ADE processor did not emit a structured result.")
    return result_payload


def execute_processor(sink):
    emit_log(sink, "executeRun", "info", "Downloading input artifact")
    download_input()
    emit_status(sink, "executeRun", "started")
    LOCAL_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    try:
        result = stream_subprocess(
            sink,
            "executeRun",
            [
                sys.executable,
                "-c",
                processor_code(),
                str(LOCAL_INPUT_PATH),
                str(LOCAL_OUTPUT_DIR),
            ],
            expect_result=True,
        )
    except Exception as error:
        raise AdePhaseError("executeRun", error) from error
    emit_status(sink, "executeRun", "completed")
    return result


def upload_output(sink, result):
    emit_status(sink, "persistOutputs", "started")
    try:
        local_output_path = Path(result["localOutputPath"])
        body = local_output_path.read_bytes()
        http_request("PUT", CONFIG["outputUpload"], body)
    except Exception as error:
        raise AdePhaseError("persistOutputs", error) from error

    sink.emit(
        {
            "type": "result",
            "outputPath": CONFIG["outputPath"],
            "validationIssues": result["validationIssues"],
        }
    )
    emit_status(sink, "persistOutputs", "completed")


def main():
    with WebSocketEmitter() as sink:
        sink.ready()
        try:
            install_packages(sink)
            result = execute_processor(sink)
            upload_output(sink, result)
        except AdePhaseError as error:
            emit_error(sink, error.phase, error, error.retriable)
            raise
        except Exception as error:
            emit_error(sink, "executeRun", error, False)
            raise


if __name__ == "__main__":
    main()
