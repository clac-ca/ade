import codecs
import errno
import json
import os
import pty
import shutil
import signal
import subprocess
import sys
import threading
import time

CONFIG = json.loads({{CONFIG_JSON}})


def _install_websockets():
    try:
        from websockets.sync.client import connect  # noqa: F401
    except Exception:
        subprocess.run(
            [
                sys.executable,
                "-m",
                "pip",
                "install",
                "--disable-pip-version-check",
                "websockets>=15,<16",
            ],
            check=True,
        )
    from websockets.sync.client import connect

    return connect


def _set_winsize(fd: int, rows: int, cols: int) -> None:
    try:
        import fcntl
        import struct
        import termios

        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except Exception:
        return


def _encode(message: dict[str, object]) -> str:
    return json.dumps(message, separators=(",", ":"))


def _decode_text(message: str | bytes) -> str:
    if isinstance(message, bytes):
        return message.decode("utf-8", errors="replace")
    return message


def main() -> None:
    connect = _install_websockets()
    shell = shutil.which("bash") or shutil.which("sh")
    if shell is None:
        raise RuntimeError("Could not locate a shell executable inside the session.")

    master_fd, slave_fd = pty.openpty()
    _set_winsize(slave_fd, CONFIG["rows"], CONFIG["cols"])
    process = subprocess.Popen(
        [shell, "-i"],
        stdin=slave_fd,
        stdout=slave_fd,
        stderr=slave_fd,
        cwd="/mnt/data",
        start_new_session=True,
        close_fds=True,
    )
    os.close(slave_fd)
    os.set_blocking(master_fd, False)
    stop_event = threading.Event()
    thread_errors: list[BaseException] = []

    with connect(
        CONFIG["bridgeUrl"],
        ping_interval=20,
        ping_timeout=20,
        max_size=None,
    ) as websocket:
        websocket.send(_encode({"type": "ready"}))
        decoder = codecs.getincrementaldecoder("utf-8")("replace")

        def record_thread_error(error: BaseException) -> None:
            if thread_errors:
                return
            thread_errors.append(error)
            stop_event.set()

        def forward_pty() -> None:
            try:
                while not stop_event.is_set():
                    try:
                        data = os.read(master_fd, 4096)
                    except BlockingIOError:
                        if process.poll() is not None:
                            break
                        time.sleep(0.01)
                        continue
                    except OSError as error:
                        if error.errno == errno.EIO:
                            break
                        raise

                    if not data:
                        if process.poll() is not None:
                            break
                        time.sleep(0.01)
                        continue

                    websocket.send(
                        _encode(
                            {
                                "type": "output",
                                "data": decoder.decode(data),
                            }
                        )
                    )

                tail = decoder.decode(b"", final=True)
                if tail and not stop_event.is_set():
                    websocket.send(_encode({"type": "output", "data": tail}))

                return_code = process.wait()
                if not stop_event.is_set():
                    websocket.send(
                        _encode(
                            {
                                "type": "exit",
                                "code": return_code,
                            }
                        )
                    )
            except Exception as error:
                record_thread_error(error)
            finally:
                stop_event.set()

        output_thread = threading.Thread(target=forward_pty, daemon=True)
        output_thread.start()

        try:
            while not stop_event.is_set():
                try:
                    raw_message = websocket.recv(timeout=1)
                except TimeoutError:
                    continue
                except Exception:
                    break

                message = json.loads(_decode_text(raw_message))
                message_type = message.get("type")

                if message_type == "input":
                    os.write(master_fd, str(message.get("data", "")).encode("utf-8"))
                    continue

                if message_type == "resize":
                    _set_winsize(
                        master_fd,
                        int(message.get("rows", CONFIG["rows"])),
                        int(message.get("cols", CONFIG["cols"])),
                    )
                    continue

                if message_type == "close":
                    try:
                        os.killpg(os.getpgid(process.pid), signal.SIGTERM)
                    except ProcessLookupError:
                        pass
                    break
        finally:
            stop_event.set()
            output_thread.join(timeout=5)
            try:
                os.close(master_fd)
            except OSError:
                pass
            if process.poll() is None:
                try:
                    os.killpg(os.getpgid(process.pid), signal.SIGTERM)
                except ProcessLookupError:
                    pass

    if thread_errors:
        raise thread_errors[0]


main()
